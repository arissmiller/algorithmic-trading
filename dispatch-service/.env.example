PORT=3003
ALLOWED_ORIGINS=http://127.0.0.1:1420
REQUIRE_ORIGIN_HEADER=false

# Shared auth for /api/dispatch/* endpoints.
DISPATCH_AUTH_HEADER=x-dispatch-token
DISPATCH_AUTH_TOKEN=replace-me

# Local persistence paths (ephemeral on Railway unless mounted volume is used).
DISPATCH_STATE_FILE=./dispatch-state.json
DISPATCH_TRADING_STATE_FILE=./dispatch-trading-state.json
DISPATCH_EVENT_HISTORY_LIMIT=500

# In development, keep these true so the service logs outbound messages instead of sending.
# For SMTP live delivery with SMS placeholder mode:
# - set email log-only false (real SMTP send)
# - keep SMS log-only true (skipped placeholder)
DISPATCH_EMAIL_LOG_ONLY_MODE=false
DISPATCH_SMS_LOG_ONLY_MODE=true

# SMTP (required only when DISPATCH_EMAIL_LOG_ONLY_MODE=false)
DISPATCH_SMTP_HOST=
DISPATCH_SMTP_PORT=587
DISPATCH_SMTP_SECURE=false
DISPATCH_SMTP_USER=
DISPATCH_SMTP_PASS=
DISPATCH_SMTP_FROM_EMAIL=no-reply@example.com
DISPATCH_SMTP_FROM_NAME=Smart Scale
DISPATCH_SMTP_REPLY_TO=

# Twilio (required only when DISPATCH_SMS_LOG_ONLY_MODE=false)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_PHONE_E164=
