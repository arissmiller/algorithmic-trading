{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "strict": true,
    "skipLibCheck": true,
    "types": ["node"]
  },
  "include": [
    "server.ts",
    "core.ts",
    "barsCache.ts",
    "bot.ts",
    "botSignals.ts",
    "watchlistExecution.ts",
    "signalDispatch.ts",
    "api/**/*.ts"
  ]
}
