PORT=3002
ALLOWED_ORIGINS=http://127.0.0.1:1420
DATABASE_URL=postgres://postgres:postgres@127.0.0.1:5432/algorithmic_trader
AUTH_TOKEN_TTL_SECONDS=2592000
EMAIL_VERIFICATION_REQUIRED=true
EMAIL_VERIFICATION_TOKEN_TTL_SECONDS=86400
EMAIL_VERIFICATION_BASE_URL=http://127.0.0.1:1420
EMAIL_VERIFICATION_LOG_ONLY_MODE=true
AUTH_EXPOSE_VERIFICATION_TOKEN=false

# SMTP (optional in local dev when EMAIL_VERIFICATION_LOG_ONLY_MODE=true)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=example-user
SMTP_PASS=example-pass
SMTP_FROM_EMAIL=no-reply@example.com
SMTP_FROM_NAME=Smart Scale
SMTP_REPLY_TO=support@example.com
